{
  "name": "tallybridge",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "description": "Prototype bridge between a real ATEM switcher and Ethernet tally clients.",
  "repository": {
    "type": "git",
    "url": "git@github.com:lcorneliussen/tallybridge.git"
  },
  "homepage": "https://github.com/lcorneliussen/tallybridge",
  "bugs": {
    "url": "https://github.com/lcorneliussen/tallybridge/issues"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/src/index.js",
    "test": "node --import tsx --test test/*.test.ts",
    "pack:bundle": "bash scripts/build-release-bundle.sh",
    "pack:deb": "bash scripts/build-deb.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "atem-connection": "^3.9.0"
  }
}
